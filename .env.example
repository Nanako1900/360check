# =============================================================================
# C5 根 docker-compose.yaml 本地模拟用环境。复制为 .env（已 gitignore）即可
# `docker compose up` 本地起整栈，验证 Coolify 部署形态。
#
# 生产无需本文件：Coolify 首次部署【自动生成并持久化】SERVICE_* magic 变量，
# 其余（VITE_*/COS/管理员口令）在 Coolify UI 配置。本文件仅供本地验证。
# =============================================================================

# --- Coolify magic 变量（本地占位；生产由 Coolify 生成）---
SERVICE_PASSWORD_DB=c5_local_db_pw
SERVICE_PASSWORD_REDIS=c5_local_redis_pw
# 64 字符（≥ 32 字节，满足 HS256 强度校验）。生产用 SERVICE_BASE64_64_JWT 自动生成。
SERVICE_BASE64_64_JWT=0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ01
# 本地无公网域名留空；生产由 Coolify 注入 web 的 FQDN。
SERVICE_FQDN_WEB_8080=

# --- 前端 build 期变量（公开值；Coolify 须勾选「Build Variable」）---
VITE_API_BASE_URL=/api/v1
VITE_MAP_KEY=
VITE_CDN_BASE=

# --- 首次建管理员（仅首部署需要；建完从 Coolify 删除）---
C5_BOOTSTRAP_ADMIN_PASSWORD=

# --- 腾讯云 COS / CDN（外部；本地留空 → media 走内存 mock，可正常起栈）---
C5_COS_SECRET_ID=
C5_COS_SECRET_KEY=
C5_COS_APP_ID=
C5_COS_REGION=ap-guangzhou
C5_COS_BUCKET_ORIGINAL=
C5_COS_BUCKET_WEB=
C5_COS_BUCKET_THUMB=
C5_COS_CDN_DOMAIN=
C5_COS_STS_ROLE_ARN=
