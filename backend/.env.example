# C5 backend configuration. Copy to .env (gitignored) for local dev; in
# production these come from K8s Secrets / 密管, never the repo.
# All keys are prefixed C5_ and nested keys use underscores (C5_DB_DSN -> db.dsn).

# --- core (fail-fast required) ---
C5_DB_DSN=postgres://c5:c5@localhost:5432/c5?sslmode=disable
C5_REDIS_ADDR=localhost:6379
C5_JWT_SECRET=change-me-to-a-random-32-byte-min-secret

# --- server ---
C5_ENV=dev
C5_SERVER_PORT=8080
C5_SERVER_MODE=debug            # debug | release | test
C5_SERVER_SHUTDOWN_TIMEOUT=15s
# Comma-separated ingress proxy CIDRs/IPs trusted for X-Forwarded-For. Empty =>
# trust none (ClientIP = direct peer; cannot be spoofed to bypass per-IP rate
# limiting). Behind a load balancer, set this to the LB egress CIDR for correct
# per-client IPs.
C5_SERVER_TRUSTED_PROXIES=

# --- database pool ---
C5_DB_MAX_CONNS=10
C5_DB_MIN_CONNS=2
C5_DB_HEALTH_CHECK=30s

# --- redis ---
C5_REDIS_PASSWORD=
C5_REDIS_DB=0

# --- jwt ---
C5_JWT_ISSUER=c5-api
C5_JWT_ACCESS_TTL=15m
C5_JWT_REFRESH_TTL=720h

# --- bootstrap admin (the seed ships admin LOCKED; no default credential) ---
# Set a strong value, then run once:  c5-api create-admin
# (reads these from env, bcrypt-hashes at cost 12, sets the admin password).
C5_BOOTSTRAP_ADMIN_USERNAME=admin
C5_BOOTSTRAP_ADMIN_PASSWORD=

# --- tencent COS / CAM STS (validated lazily at P5; not needed for P0/healthz) ---
C5_COS_SECRET_ID=
C5_COS_SECRET_KEY=
C5_COS_APP_ID=
C5_COS_REGION=ap-guangzhou
C5_COS_BUCKET_ORIGINAL=
C5_COS_BUCKET_WEB=
C5_COS_BUCKET_THUMB=
C5_COS_CDN_DOMAIN=
C5_COS_STS_ROLE_ARN=

# --- observability ---
C5_OBSERV_SERVICE_NAME=c5-api
C5_OBSERV_OTLP_ENDPOINT=        # e.g. otel-collector:4317 (P7)
